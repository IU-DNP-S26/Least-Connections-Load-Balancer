{
  "id": null,
  "uid": "least-connections-overview",
  "title": "Least Connections Overview",
  "tags": ["load-balancer", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "RPS Total",
      "id": 1,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(lb_requests_total[1m]))",
          "legendFormat": "rps",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RPS by Backend",
      "id": 2,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "sum by (backend) (rate(lb_requests_total[1m]))",
          "legendFormat": "{{backend}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx Rate",
      "id": 3,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(lb_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Latency p95 (s)",
      "id": 4,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(lb_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "In-flight Requests",
      "id": 5,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "lb_inflight_requests",
          "legendFormat": "inflight",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Serving Requests by Backend",
      "id": 6,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "lb_backend_serving_requests",
          "legendFormat": "{{backend}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Backends Alive",
      "id": 7,
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["sum"],
          "fields": ""
        },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "sum(lb_backend_alive)",
          "legendFormat": "alive",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Backend Health",
      "id": 8,
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "lb_backend_alive",
          "legendFormat": "{{backend}}",
          "refId": "A"
        }
      ]
    }
  ]
}
